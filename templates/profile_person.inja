<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ seo.title }}</title>
    <meta name="description" content="{{ seo.description }}">
    
    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json">
{{ jsonld }}
    </script>
    
    <!-- Open Graph Meta Tags -->
    {% for tag in openGraph %}
    <meta property="{{ tag.property }}" content="{{ tag.content }}">
    {% endfor %}
    
    <!-- Twitter Card Meta Tags -->
    {% for tag in twitterCard %}
    <meta name="{{ tag.name }}" content="{{ tag.content }}">
    {% endfor %}
    
    <!-- Additional SEO -->
    <link rel="canonical" href="{{ baseUrl }}/{{ profile.slug }}">
    <meta name="robots" content="index, follow">
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            line-height: 1.6;
            color: #333;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }
        
        .container {
            max-width: 800px;
            margin: 0 auto;
            background: white;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            overflow: hidden;
        }
        
        .header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 40px;
            text-align: center;
        }
        
        .header h1 {
            font-size: 2.5rem;
            margin-bottom: 10px;
            font-weight: 600;
        }
        
        .header .subtitle {
            font-size: 1.2rem;
            opacity: 0.9;
        }
        
        .content {
            padding: 40px;
        }
        
        .profile-section {
            margin-bottom: 30px;
        }
        
        .profile-section h2 {
            font-size: 1.5rem;
            margin-bottom: 15px;
            color: #667eea;
            border-bottom: 2px solid #667eea;
            padding-bottom: 10px;
        }
        
        .profile-section p {
            margin-bottom: 10px;
            color: #555;
        }
        
        .bio {
            font-size: 1.1rem;
            line-height: 1.8;
            color: #444;
        }
        
        .info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
            margin-top: 15px;
        }
        
        .info-item {
            padding: 15px;
            background: #f8f9fa;
            border-radius: 8px;
        }
        
        .info-label {
            font-weight: 600;
            color: #667eea;
            margin-bottom: 5px;
        }
        
        .info-value {
            color: #555;
        }
        
        .links-section {
            margin-top: 30px;
        }
        
        .link-block {
            display: block;
            padding: 15px 20px;
            margin-bottom: 10px;
            background: #f8f9fa;
            border-radius: 8px;
            text-decoration: none;
            color: #333;
            transition: all 0.3s ease;
            border-left: 4px solid #667eea;
        }
        
        .link-block:hover {
            background: #e9ecef;
            transform: translateX(5px);
        }
        
        .link-block-title {
            font-weight: 600;
            font-size: 1.1rem;
            margin-bottom: 5px;
        }
        
        .link-block-url {
            font-size: 0.9rem;
            color: #667eea;
        }
        
        .skills-list {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-top: 10px;
        }
        
        .skill-tag {
            background: #667eea;
            color: white;
            padding: 8px 16px;
            border-radius: 20px;
            font-size: 0.9rem;
        }
        
        .footer {
            text-align: center;
            padding: 20px;
            background: #f8f9fa;
            color: #666;
            font-size: 0.9rem;
        }
        
        @media (max-width: 768px) {
            body {
                padding: 10px;
            }
            
            .header h1 {
                font-size: 2rem;
            }
            
            .content {
                padding: 20px;
            }
            
            .info-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>{{ profile.name }}</h1>
            {% if existsIn(profile, "title") %}
            <p class="subtitle">{{ profile.title }}</p>
            {% endif %}
            {% if existsIn(profile, "company") %}
            <p class="subtitle">@ {{ profile.company }}</p>
            {% endif %}
        </div>
        
        <div class="content">
            {% if existsIn(profile, "bio") %}
            <div class="profile-section">
                <h2>About</h2>
                <p class="bio">{{ profile.bio }}</p>
            </div>
            {% endif %}
            
            {% if existsIn(profile, "title") or existsIn(profile, "company") or existsIn(profile, "experienceLevel") %}
            <div class="profile-section">
                <h2>Professional Information</h2>
                <div class="info-grid">
                    {% if existsIn(profile, "title") %}
                    <div class="info-item">
                        <div class="info-label">Job Title</div>
                        <div class="info-value">{{ profile.title }}</div>
                    </div>
                    {% endif %}
                    
                    {% if existsIn(profile, "company") %}
                    <div class="info-item">
                        <div class="info-label">Company</div>
                        <div class="info-value">{{ profile.company }}</div>
                    </div>
                    {% endif %}
                    
                    {% if existsIn(profile, "experienceLevel") %}
                    <div class="info-item">
                        <div class="info-label">Experience Level</div>
                        <div class="info-value">{{ profile.experienceLevel }}</div>
                    </div>
                    {% endif %}
                </div>
            </div>
            {% endif %}
            
            {% if existsIn(profile, "education") or existsIn(profile, "school") %}
            <div class="profile-section">
                <h2>Education</h2>
                <div class="info-grid">
                    {% if existsIn(profile, "education") %}
                    <div class="info-item">
                        <div class="info-label">Degree</div>
                        <div class="info-value">{{ profile.education }}</div>
                    </div>
                    {% endif %}
                    
                    {% if existsIn(profile, "school") %}
                    <div class="info-item">
                        <div class="info-label">School</div>
                        <div class="info-value">{{ profile.school }}</div>
                    </div>
                    {% endif %}
                </div>
            </div>
            {% endif %}
            
            {% if existsIn(profile, "skills") and length(profile.skills) > 0 %}
            <div class="profile-section">
                <h2>Skills & Expertise</h2>
                <div class="skills-list">
                    {% for skill in profile.skills %}
                    <span class="skill-tag">{{ skill }}</span>
                    {% endfor %}
                </div>
            </div>
            {% endif %}
            
            {% if existsIn(links, "length") and length(links) > 0 %}
            <div class="profile-section">
                <h2>Links</h2>
                <div class="links-section">
                    {% for link in links %}
                    <a href="/l/{{ link.id }}" class="link-block" target="_blank" rel="noopener noreferrer">
                        <div class="link-block-title">{{ link.title }}</div>
                        <div class="link-block-url">{{ link.url }}</div>
                    </a>
                    {% endfor %}
                </div>
            </div>
            {% endif %}
        </div>
        
        <div class="footer">
            <p>Powered by <strong>Hatef.ir</strong> - Professional Profile Platform</p>
        </div>
    </div>
</body>
</html>
